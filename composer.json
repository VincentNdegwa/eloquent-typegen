{
    "name": "based/eloquent-typegen",
    "description": "Generate TypeScript types from Eloquent models",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Based\\EloquentTypegen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Based\\EloquentTypegen\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "VincentNdegwa",
            "email": "ndegwavincent7@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=80",
        "analyse": "phpstan analyse",
        "format": "pint",
        "check": [
            "@format",
            "@analyse",
            "@test"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Based\\EloquentTypegen\\EloquentTypegenServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
